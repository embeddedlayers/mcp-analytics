{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-09-29/server.schema.json",
  "name": "ai.mcpanalytics/analytics",
  "description": "The statistical analyst in your AI chat \u2014 validated, citable, re-runnable analysis of your data.",
  "version": "1.0.6",
  "author": {
    "name": "MCP Analytics",
    "email": "support@mcpanalytics.ai",
    "url": "https://mcpanalytics.ai"
  },
  "license": "MIT",
  "homepage": "https://mcpanalytics.ai",
  "repository": {
    "url": "https://github.com/embeddedlayers/mcp-analytics",
    "source": "github"
  },
  "categories": [
    "analytics",
    "data-science",
    "statistics",
    "machine-learning"
  ],
  "keywords": [
    "statistics",
    "data-analysis",
    "reports",
    "citable",
    "reproducible",
    "regression",
    "clustering",
    "time-series",
    "machine-learning",
    "snapshot",
    "atlas",
    "oauth2",
    "encrypted"
  ],
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://api.mcpanalytics.ai/mcp/api-key",
      "authentication": {
        "type": "api-key",
        "header": "X-API-Key"
      }
    },
    {
      "type": "streamable-http",
      "url": "https://api.mcpanalytics.ai/auth0",
      "authentication": {
        "type": "oauth2",
        "authorizationUrl": "https://api.mcpanalytics.ai/oauth2/authorize",
        "tokenUrl": "https://api.mcpanalytics.ai/oauth2/token",
        "scopes": [
          "openid",
          "profile",
          "email",
          "execute:tools"
        ],
        "pkce": true
      }
    },
    {
      "type": "streamable-http",
      "url": "https://api.mcpanalytics.ai/mcp/discover",
      "authentication": {
        "type": "none"
      }
    }
  ],
  "capabilities": {
    "tools": true,
    "resources": true,
    "prompts": true
  },
  "examples": [
    {
      "title": "Instant Snapshot report",
      "description": "Commission an instant automated analysis of your data",
      "code": "create_analysis(fuzzy_request='does ad spend drive sales?', dataset_ref='uuid://...', tier='snapshot')"
    },
    {
      "title": "Commission a deep analysis (Atlas)",
      "description": "A durable, re-runnable analysis module built for your question (~1 hour, never billed on failure)",
      "code": "create_analysis(fuzzy_request='what drives churn?', dataset_ref='uuid://...', tier='atlas') then build_status(pipeline_id)"
    },
    {
      "title": "Re-run an analysis on fresh data",
      "description": "Your commissioned modules re-run anytime \u2014 including on live connector data",
      "code": "run_analysis(tool_name='<your module>', taskList={inputs: {dataset: 'connector://mcpanalytics_ga4/report?...'}})"
    }
  ],
  "documentation": {
    "quickstart": "https://mcpanalytics.ai/docs/quickstart",
    "tools": "https://mcpanalytics.ai/tools",
    "api": "https://api.mcpanalytics.ai/docs"
  },
  "support": {
    "issues": "support@mcpanalytics.ai",
    "email": "support@mcpanalytics.ai"
  }
}